# Copy this file to `.env` and fill in your local values.

# PostgreSQL connection
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=inventory_app

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
